# 迁移到 Nacos 后，部署机上的最小 .env 示例
# 说明：
# 1. 数据库、Redis、ES、COS、短信、邮件、OAuth、AI、前端域名等业务配置统一放到 Nacos
# 2. 这里仅保留镜像 / 端口 / Nacos / Sentinel 引导变量

# Runtime / deployment
NGINX_HTTP_PORT=80
BACKEND_PORT=8101
BACKEND_IMAGE=crpi-ydpr7w8k736zbt54.cn-shanghai.personal.cr.aliyuncs.com/<your-namespace>/intelligent-interview-backend:latest
FRONTEND_IMAGE=crpi-ydpr7w8k736zbt54.cn-shanghai.personal.cr.aliyuncs.com/<your-namespace>/intelligent-interview-frontend:latest
NGINX_IMAGE=crpi-ydpr7w8k736zbt54.cn-shanghai.personal.cr.aliyuncs.com/<your-namespace>/intelligent-interview-nginx:latest

# Nacos / Sentinel
NACOS_DISCOVERY_SERVER_ADDR=127.0.0.1:8848
NACOS_DISCOVERY_USERNAME=
NACOS_DISCOVERY_PASSWORD=
NACOS_CONFIG_SERVER_ADDR=127.0.0.1:8848
NACOS_CONFIG_USERNAME=
NACOS_CONFIG_PASSWORD=
SENTINEL_DASHBOARD=
