# ----------------------------
# Runtime / deployment
# ----------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_CERTS_DIR=/opt/intelliface/certs
BACKEND_PORT=8101
BACKEND_IMAGE=ghcr.io/<github-owner>/intelligent-interview-backend:latest
FRONTEND_IMAGE=ghcr.io/<github-owner>/intelligent-interview-frontend:latest
NGINX_IMAGE=nginx:1.27-alpine

# ----------------------------
# Nacos / Sentinel
# 说明：数据库、Redis、ES、短信、邮件、OAuth、AI、前端域名等业务配置
# 建议统一写到 Nacos 的 common.yml / Intelligent-interview-question-bank-system.yml
# ----------------------------
NACOS_DISCOVERY_SERVER_ADDR=127.0.0.1:8848
NACOS_DISCOVERY_USERNAME=
NACOS_DISCOVERY_PASSWORD=
NACOS_CONFIG_SERVER_ADDR=127.0.0.1:8848
NACOS_CONFIG_USERNAME=
NACOS_CONFIG_PASSWORD=
SENTINEL_DASHBOARD=
