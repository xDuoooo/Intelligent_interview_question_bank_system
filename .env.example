# ----------------------------
# Public domain
# ----------------------------
FRONTEND_URL=http://your-domain.com
APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://your-domain.com
NGINX_HTTP_PORT=80

# ----------------------------
# MySQL
# ----------------------------
DB_URL=jdbc:mysql://mysql-host:3306/Intelligent_interview_question_bank_system?useUnicode=true&characterEncoding=utf8&connectionCollation=utf8mb4_unicode_ci&serverTimezone=Asia/Shanghai
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ----------------------------
# Redis
# ----------------------------
REDIS_DATABASE=1
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------
# Elasticsearch
# ----------------------------
ES_URIS=http://es-host:9200
ES_USERNAME=
ES_PASSWORD=

# ----------------------------
# Mail
# ----------------------------
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=

# ----------------------------
# COS / local upload fallback
# ----------------------------
COS_ACCESS_KEY=
COS_SECRET_KEY=
COS_REGION=ap-beijing
COS_BUCKET=
COS_HOST=
APP_UPLOAD_LOCAL_FALLBACK_ENABLED=true

# ----------------------------
# SMS
# ----------------------------
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=智面平台
ALIYUN_SMS_TEMPLATE_CODE=
APP_SMS_MOCK_ENABLED=false

# ----------------------------
# OAuth
# ----------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://your-domain.com/api/user/login/github/callback

GITEE_CLIENT_ID=
GITEE_CLIENT_SECRET=
GITEE_REDIRECT_URI=http://your-domain.com/api/user/login/gitee/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://your-domain.com/api/user/login/google/callback

# ----------------------------
# AI
# ----------------------------
AI_API_KEY=
AI_HOST=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_SPEECH_MODEL=whisper-1

# ----------------------------
# Optional docs auth
# ----------------------------
KNIFE4J_ENABLE=false
KNIFE4J_BASIC_ENABLE=false
KNIFE4J_USERNAME=
KNIFE4J_PASSWORD=
